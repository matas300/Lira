# ────────────────────────────────────────────────────────────────────────────
# Lira — variabili d'ambiente
# Copia in .env e compila. Non committare .env.
# ────────────────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=8787
PUBLIC_BASE_URL=http://localhost:8787

# Sessions — segreto firma cookie (32+ char random)
SESSION_SECRET=change-me-to-a-long-random-string-32chars-min

# Database (Turso libSQL)
# In dev locale puoi anche usare: file:local.db
DATABASE_URL=libsql://your-db-name.turso.io
DATABASE_AUTH_TOKEN=eyJhbGc...

# OpenAPI (autofill cliente da P.IVA — opzionale, ereditato da CalcoliVari)
OPENAPI_KEY=
